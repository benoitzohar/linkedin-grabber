{
  "manifest_version": 3,
  "name": "LinkedIn Grabber",
  "version": "1.0.0",
  "description": "Copy linked LinkedIn profile bullets from open Recruiter or public profile tabs.",
  "permissions": ["tabs", "scripting", "clipboardRead", "clipboardWrite"],
  "host_permissions": ["https://www.linkedin.com/*"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "LinkedIn Grabber",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  }
}
